# Supabase (PostgreSQL) connection strings.
# Supabase dashboard: Project Settings > Database > Connection string
#
# DATABASE_URL: アプリの通常動作用。Connection Pooler(Transaction mode, ポート 6543)。
# Vercel などのサーバーレス環境で同時接続数を抑えるために使用します。
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: `prisma migrate` などマイグレーション/イントロスペクション専用。
# プーラーを経由しない直接接続(Session mode, ポート 5432)。
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@[YOUR-REGION].pooler.supabase.com:5432/postgres"

# 「設定」パネル(選手の確認・削除)に入るためのパスワード。
SETTINGS_PASSWORD="[CHOOSE-A-PASSWORD]"

# LINE Developers コンソール > チャネル > Messaging API設定 で発行。
LINE_CHANNEL_ACCESS_TOKEN="[YOUR-LINE-CHANNEL-ACCESS-TOKEN]"
# 同じくチャネル基本設定にある「チャネルシークレット」。
LINE_CHANNEL_SECRET="[YOUR-LINE-CHANNEL-SECRET]"
# 毎日の「今日の欠席」通知を送る相手のLINE User ID。
# /api/line/webhook にメッセージを送ると、その場で本人のUser IDが返信されます。
LINE_TARGET_USER_ID="[LINE-USER-ID]"

# VercelのCronジョブから /api/line/notify-today を叩く際の認証用シークレット。
# 任意のランダムな文字列でOK。Vercel側で同名の環境変数を設定すると、
# Cronリクエストのヘッダーに自動で付与されます。
CRON_SECRET="[CHOOSE-A-RANDOM-SECRET]"
