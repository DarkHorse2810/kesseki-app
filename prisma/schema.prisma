// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Position {
  PITCHER
  CATCHER
  INFIELDER
  OUTFIELDER
  MANAGER
  ANALYST
}

model Player {
  id        Int              @id @default(autoincrement())
  name      String
  baseGrade Int
  baseYear  Int
  pin       String           @unique
  positions PlayerPosition[]
  absences  Absence[]
}

model PlayerPosition {
  id       Int      @id @default(autoincrement())
  playerId Int
  player   Player   @relation(fields: [playerId], references: [id])
  position Position
}

model Absence {
  id       Int      @id @default(autoincrement())
  playerId Int
  player   Player   @relation(fields: [playerId], references: [id])
  date     DateTime
  reason   String
}

model ScheduleItem {
  id   Int      @id @default(autoincrement())
  date DateTime
  text String
}

// 0 = Sunday ... 6 = Saturday. time is "HH:MM" in JST, null = don't send.
model WeekdaySchedule {
  weekday Int     @id
  time    String?
}

// Per-date override of the weekday default. time is "HH:MM" in JST,
// null = skip sending on this date.
model DateOverride {
  date DateTime @id
  time String?
}

// One row per calendar date (JST) that a notification has already been
// sent for, to avoid duplicate sends across multiple cron checks.
model NotificationLog {
  date   DateTime @id
  sentAt DateTime @default(now())
}

// A LINE account that should receive the daily notification.
model NotificationRecipient {
  id         Int      @id @default(autoincrement())
  lineUserId String   @unique
  label      String?
  createdAt  DateTime @default(now())
}

// A LINE group/room that gets an immediate message the moment a new
// absence is submitted through the site.
model RealtimeAbsenceTarget {
  id        Int      @id @default(autoincrement())
  lineId    String   @unique // LINE groupId or roomId
  label     String?
  createdAt DateTime @default(now())
}

// Tracks which chat (group/room/user) has already been told its ID via the
// webhook's auto-reply, so we only announce it once and stay quiet after
// that instead of replying to every single message in the group.
model WebhookGreetedSource {
  id        String   @id // e.g. "group:<groupId>", "room:<roomId>", "user:<userId>"
  greetedAt DateTime @default(now())
}
